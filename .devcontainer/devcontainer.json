{
  "name": "Equities Trading Simulator",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "forwardPorts": [8080, 5000, 5001, 5002, 5003, 5004, 5005, 5006, 5007, 5008, 9879, 9881],
  "portsAttributes": {
    "8080": { "label": "Frontend UI", "onAutoForward": "openBrowserOnce", "protocol": "http", "elevateIfNeeded": false },
    "5000": { "label": "Market Sim", "onAutoForward": "ignore" },
    "5001": { "label": "EMS", "onAutoForward": "ignore" },
    "5002": { "label": "OMS", "onAutoForward": "ignore" },
    "5003": { "label": "Limit Algo", "onAutoForward": "ignore" },
    "5004": { "label": "TWAP Algo", "onAutoForward": "ignore" },
    "5005": { "label": "POV Algo", "onAutoForward": "ignore" },
    "5006": { "label": "VWAP Algo", "onAutoForward": "ignore" },
    "5007": { "label": "Observability", "onAutoForward": "ignore" },
    "5008": { "label": "User Service", "onAutoForward": "ignore" },
    "9879": { "label": "FIX Exchange (health)", "onAutoForward": "ignore" },
    "9881": { "label": "FIX Gateway (WS)", "onAutoForward": "ignore" }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "fish",
        "deno.path": "/home/deno/.deno/bin/deno"
        ,"security.workspace.trust.startupPrompt": "never"
        ,"extensions.autoUpdate": true
        ,"extensions.autoCheckUpdates": true
      },
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "anthropic.claude-code",
        "Codeium.codeium",
        "denoland.vscode-deno",
        "redhat.vscode-json",
        "foxundermoon.shell-format",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "skyapps.fish-vscode",
        "redhat.vscode-yaml",
        "yzhang.markdown-all-in-one",
        "charliermarsh.ruff",
        "ms-playwright.playwright",
        "rangav.vscode-thunder-client",
        "humao.rest-client",
        "yoavbls.pretty-ts-errors",
        "usernamehw.errorlens"
      ]
    }
  },
  "remoteUser": "deno",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/deno/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gh,target=/home/deno/.config/gh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/deno/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/deno/.claude,type=bind,consistency=cached"
  ],
  "postCreateCommand": "cd /workspaces/virtual-equities-trading-application/frontend && npm ci --ignore-scripts && cd /workspaces/virtual-equities-trading-application && ./frontend/node_modules/.bin/husky install .husky",
  "postStartCommand": "chmod 700 /home/deno/.ssh && chmod 600 /home/deno/.ssh/* || true && rm -f /var/lib/redpanda/data/pid.lock && cd /workspaces/virtual-equities-trading-application/frontend && deno install --allow-scripts && cd /workspaces/virtual-equities-trading-application && supervisord -c /home/deno/supervisord.conf"
}
