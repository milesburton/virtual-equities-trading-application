# =============================================================================
# Dockerfile.base
# Published to ghcr.io/milesburton/equities-trading-simulator/devcontainer-base
# Contains all heavy tooling that rarely changes (OS packages, runtimes, Playwright browsers).
# Rebuild via GitHub Actions (build-base-image.yml) when this file changes.
# The app .devcontainer/Dockerfile inherits FROM this image.
# =============================================================================

# Redpanda binaries — copied into the dev container so services can publish/consume
FROM redpandadata/redpanda:v24.3.6 AS redpanda-src

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    unzip \
    fish \
    git \
    python3 \
    python3-pip \
    socat \
    sqlite3 \
    shellcheck \
    ruby \
    tree \
    ssh \
    sudo \
    supervisor \
    ca-certificates \
    fonts-liberation \
    libnss3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libgbm1 \
    libasound2 \
    libxss1 \
    libxcomposite1 \
    libxrandr2 \
    libgtk-3-0 \
    libxcb1 \
    libx11-xcb1 \
    && gem install lolcat \
    && pip3 install --no-cache-dir --upgrade "git+https://github.com/openai/whisper.git@v20231117" \
    && pip install --no-cache-dir --upgrade yt-dlp \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 24 LTS (for frontend tooling & Playwright)
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* || true

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && apt-get install -y gh && rm -rf /var/lib/apt/lists/* || true

# Copy Redpanda runtime assets and place real executables on PATH.
# The redpanda binary was compiled with PT_INTERP=/opt/redpanda/lib/ld.so so we
# create that symlink to point at the actual lib directory.
COPY --from=redpanda-src /opt/redpanda/lib /usr/local/lib/redpanda
COPY --from=redpanda-src /opt/redpanda/libexec/redpanda /usr/local/bin/redpanda
COPY --from=redpanda-src /opt/redpanda/libexec/rpk /usr/local/bin/rpk
RUN chmod +x /usr/local/bin/redpanda /usr/local/bin/rpk && \
    mkdir -p /var/lib/redpanda/data /etc/redpanda /opt/redpanda && \
    ln -s /usr/local/lib/redpanda /opt/redpanda/lib
# Do NOT set LD_LIBRARY_PATH globally — Redpanda ships its own libc.so.6 which
# breaks any shell that loads it at startup. The /opt/redpanda/lib symlink
# satisfies the binary's PT_INTERP without needing LD_LIBRARY_PATH at all.

# Create the 'deno' user with Fish as default shell, and pre-create bind mount targets
RUN useradd -m -s /usr/bin/fish deno && \
    chown -R deno:deno /var/lib/redpanda /etc/redpanda && \
    mkdir -p /home/deno/.ssh /home/deno/.claude && \
    chown -R deno:deno /home/deno/.ssh /home/deno/.claude && \
    chmod 700 /home/deno/.ssh

# Install Playwright browsers as root (--with-deps needs apt), then hand off to deno user.
# Pinned to match frontend/package.json (@playwright/test ^1.58.2).
RUN npx --yes playwright@1.58.2 install --with-deps && \
    mkdir -p /home/deno/.cache && \
    mv /root/.cache/ms-playwright /home/deno/.cache/ms-playwright && \
    chown -R deno:deno /home/deno/.cache

ENV PLAYWRIGHT_BROWSERS_PATH=/home/deno/.cache/ms-playwright

# Switch to the 'deno' user
USER deno

# Set the working directory
WORKDIR /home/deno

# Ensure the Fish configuration directory exists
RUN mkdir -p /home/deno/.config/fish

# Install Deno
RUN curl -fsSL https://deno.land/x/install/install.sh | sh

# Install Fly.io CLI (as deno user, installs to ~/.fly)
RUN curl -L https://fly.io/install.sh | sh

# Update Fish config with Deno and Flyctl paths, welcome message, and aliases
RUN echo '# Deno setup' > /home/deno/.config/fish/config.fish && \
    echo 'set -gx DENO_INSTALL "$HOME/.deno"' >> /home/deno/.config/fish/config.fish && \
    echo 'fish_add_path $DENO_INSTALL/bin' >> /home/deno/.config/fish/config.fish && \
    echo 'set -gx FLYCTL_INSTALL "$HOME/.fly"' >> /home/deno/.config/fish/config.fish && \
    echo 'fish_add_path $FLYCTL_INSTALL/bin' >> /home/deno/.config/fish/config.fish && \
    echo '' >> /home/deno/.config/fish/config.fish && \
    echo 'if status is-interactive' >> /home/deno/.config/fish/config.fish && \
    echo '  echo ""' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "-------------------------------------------------" | lolcat' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "Equities Trading Simulator" | lolcat' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "-------------------------------------------------" | lolcat' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "All services start automatically via supervisord."' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "Frontend UI: http://localhost:8080"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo ""' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "Aliases:" | lolcat' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-frontend         React UI (port 8080)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-market-sim       Market price engine (port 5000)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-ems              Execution Management System (port 5001)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-oms              Order Management System (port 5002)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-limit-strategy   Limit order algo (port 5003)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-twap-strategy    TWAP algo (port 5004)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-pov-strategy     POV algo (port 5005)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-vwap-strategy    VWAP algo (port 5006)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  run-observability    Observability service (port 5007)"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "  restart-services     Restart all services via supervisord"' >> /home/deno/.config/fish/config.fish && \
    echo '  echo "-------------------------------------------------" | lolcat' >> /home/deno/.config/fish/config.fish && \
    echo 'end' >> /home/deno/.config/fish/config.fish && \
    echo '' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-frontend="cd /workspaces/equities-trading-simulator/frontend && npm run dev"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-market-sim="cd /workspaces/equities-trading-simulator && deno run --allow-all backend/src/market-sim/market-sim.ts"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-ems="cd /workspaces/equities-trading-simulator && deno run --allow-all backend/src/ems/ems-server.ts"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-oms="cd /workspaces/equities-trading-simulator && deno run --allow-all backend/src/oms/oms-server.ts"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-limit-strategy="cd /workspaces/equities-trading-simulator && deno run --allow-all backend/src/algo/limit-strategy.ts"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-twap-strategy="cd /workspaces/equities-trading-simulator && deno run --allow-all backend/src/algo/twap-strategy.ts"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-pov-strategy="cd /workspaces/equities-trading-simulator && deno run --allow-all backend/src/algo/pov-strategy.ts"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-vwap-strategy="cd /workspaces/equities-trading-simulator && deno run --allow-all backend/src/algo/vwap-strategy.ts"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias run-observability="cd /workspaces/equities-trading-simulator && deno run --allow-all backend/src/observability/observability-server.ts"' >> /home/deno/.config/fish/config.fish && \
    echo 'alias restart-services="supervisorctl restart market-sim ems oms algo-trader twap-algo pov-algo vwap-algo observability user-service && supervisorctl status"' >> /home/deno/.config/fish/config.fish

# Set Fish as the default shell
SHELL ["/usr/bin/fish", "-c"]
