    "react-hotkeys-hook": "^5.2.4",
    "react-resizable-panels": "^4.7.0",
    "react-window": "^2.2.7",
    "recharts": "^2.12.7",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^2.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
