#!/bin/sh

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
COMMIT_SHA=$(git rev-parse --short HEAD)

# Stamp the commit SHA into .env so services report the correct version
if [ -f "$REPO_ROOT/.env" ]; then
  if grep -q "^COMMIT_SHA=" "$REPO_ROOT/.env"; then
    sed -i "s/^COMMIT_SHA=.*/COMMIT_SHA=$COMMIT_SHA/" "$REPO_ROOT/.env"
  else
    echo "COMMIT_SHA=$COMMIT_SHA" >> "$REPO_ROOT/.env"
  fi
fi

echo "Pre-commit checks... (commit: $COMMIT_SHA)"

echo "  [1/7] Backend lint..."
cd "$REPO_ROOT"
deno task lint

echo "  [2/7] Backend type-check..."
deno task check

echo "  [3/7] Backend unit tests..."
deno task test

echo "  [4/7] Frontend lint (all files)..."
cd "$REPO_ROOT/frontend"
deno run -A npm:@biomejs/biome check src/

echo "  [5/7] Frontend type-check (all files)..."
./node_modules/.bin/tsc --noEmit --skipLibCheck

echo "  [6/7] Frontend unit tests..."
./node_modules/.bin/vitest run

echo "  [7/7] Smoke tests (skipped if services offline)..."
cd "$REPO_ROOT"
if curl -sf http://localhost:5000/health >/dev/null 2>&1; then
  deno task test:smoke
else
  echo "       Services not running — skipping smoke tests."
fi

echo "Pre-commit checks passed."
